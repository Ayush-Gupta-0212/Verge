# ── Verge environment ────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values for local dev.
# `.env.local` is gitignored. For production, set these in your host's
# dashboard (Vercel, Fly, Railway, etc.) — never check secrets in.

# ── Supabase (required for auth + per-user data) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used exclusively by /api/account/delete to fully delete a
# user from auth.users (which the anon client cannot do). Never prefix this
# with NEXT_PUBLIC_ and never expose it to the browser.
# Get it from Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telemetry (optional — leave blank to disable error reporting) ────────
# A Sentry DSN, or any HTTPS endpoint that accepts the Sentry envelope
# format. If unset, the client / server reporter is a no-op.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── App metadata (optional) ──────────────────────────────────────────────
# Public URL the app is deployed at — used for share-cards, OG metadata,
# and absolute links. Falls back to request origin when missing.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment label included in telemetry events (production / preview /
# development). Defaults to NODE_ENV.
NEXT_PUBLIC_APP_ENV=development

# ── Android TWA / Play Store (optional) ──────────────────────────────────
# Only needed once you've generated an Android wrapper (Bubblewrap or
# PWABuilder) and are uploading it to the Play Store. These two values let
# /.well-known/assetlinks.json prove the app belongs to this domain, which
# is what gets rid of the Chrome URL bar inside the installed app.
#
# TWA_PACKAGE_NAME          — the Android package id you chose, e.g.
#                             app.verge.twa
# TWA_SHA256_FINGERPRINTS   — comma-separated SHA-256 fingerprints of every
#                             signing cert that should be trusted (typically
#                             your debug key for testing AND the upload key
#                             Play console gives you for production). Each
#                             fingerprint is the colon-separated 32-byte hex
#                             you get from:
#                               keytool -list -v -keystore <keystore.jks> \
#                                 -alias <alias>
#                             or from Play Console → Setup → App integrity.
TWA_PACKAGE_NAME=
TWA_SHA256_FINGERPRINTS=
